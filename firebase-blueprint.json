{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the TraderERP system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sku", "price", "quantity", "createdAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed sale transaction.",
      "type": "object",
      "properties": {
        "totalAmount": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "totalPrice": { "type": "number" }
            },
            "required": ["productId", "productName", "quantity", "unitPrice", "totalPrice"]
          }
        }
      },
      "required": ["totalAmount", "createdBy", "createdAt", "items"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "A record of stock changes.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT", "ADJUSTMENT"] },
        "quantity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["productId", "type", "quantity", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Inventory products."
    },
    "/sales/{saleId}": {
      "schema": { "$ref": "#/entities/Sale" },
      "description": "Completed sales."
    },
    "/stock_movements/{movementId}": {
      "schema": { "$ref": "#/entities/StockMovement" },
      "description": "Stock adjustment logs."
    }
  }
}
